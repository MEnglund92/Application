{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/backend/app/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            }
        },
        {
            "name": "Docker: Backend Debug",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "docker-compose: debug-backend",
            "platform": "python"
        }
    ]
}